{
  "info": {
    "name": "PC Store Catalog API - Testing Collection",
    "description": "Colección oficial de pruebas en Postman para el proyecto integrador de Programación 3 (NestJS, PostgreSQL, MongoDB). Contiene los endpoints de Autenticación, Usuarios, Categorías, Marcas, Productos, Carrito y Órdenes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Autenticación (Auth)",
      "item": [
        {
          "name": "Iniciar Sesión (Login JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.environment.set(\"jwt_token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@pcstore.com\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Registro de Usuario (Register)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Carlos\",\n  \"lastName\": \"Gamer\",\n  \"email\": \"carlos@gamer.com\",\n  \"password\": \"Gamer2026!\",\n  \"role\": \"user\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Usuarios (Users)",
      "item": [
        {
          "name": "Obtener Todos los Usuarios (Admin RBAC)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Catálogo (Categorías y Marcas)",
      "item": [
        {
          "name": "Crear Categoría (Tarjetas de Video)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tarjetas de Video (GPU)\",\n  \"description\": \"Tarjetas gráficas dedicadas para Gaming y Renderizado\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/categories",
              "host": ["{{base_url}}"],
              "path": ["categories"]
            }
          }
        },
        {
          "name": "Crear Marca (ASUS)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ASUS\",\n  \"website\": \"https://www.asus.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/brands",
              "host": ["{{base_url}}"],
              "path": ["brands"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Productos (Products)",
      "item": [
        {
          "name": "Crear Producto (RTX 4090)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ASUS ROG Strix GeForce RTX 4090\",\n  \"price\": 1999.99,\n  \"stock\": 15,\n  \"description\": \"GPU Tope de gama con 24GB GDDR6X\",\n  \"categoryId\": \"UUID_DE_CATEGORIA\",\n  \"brandId\": \"UUID_DE_MARCA\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "Listar Productos Disponibles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products?limit=10&page=1",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "5. Carrito de Compras (Cart & CartItems)",
      "item": [
        {
          "name": "Añadir Producto al Carrito",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"UUID_DE_PRODUCTO\",\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/cart/items",
              "host": ["{{base_url}}"],
              "path": ["cart", "items"]
            }
          }
        }
      ]
    },
    {
      "name": "6. Órdenes (Orders & OrderItems)",
      "item": [
        {
          "name": "Finalizar Compra (Generar Orden desde Carrito)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "PEGAR_AQUI_EL_TOKEN_JWT_DEL_LOGIN",
      "type": "string"
    }
  ]
}
